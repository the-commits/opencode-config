{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["PROJECT.md"],
  "plugin": ["opencode-gemini-auth@latest", "opencode-websearch-cited@latest"],
  "default_agent": "scout",
  "model": "opencode/big-pickle",
  "mcp": {
    "semgrep": {
      "type": "local",
      "command": ["semgrep", "mcp"],
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
    },
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "minimax-m2.1": {
          "name": "minimax-m2.1",
        },
        "gemma4:31b": {
          "name": "Gemma 4 31b",
        },
      },
    },
    "google": {
      "options": {
        "websearch_cited": {
          "model": "gemini-2.5-flash",
        },
      },
      "models": {
        "gemini-2.5-flash": {
          "options": {
            "thinkingConfig": {
              "thinkingBudget": 8192,
              "includeThoughts": true,
            },
          },
        },
        "gemini-2.5-pro": {
          "options": {
            "thinkingConfig": {
              "thinkingBudget": 8192,
              "includeThoughts": true,
            },
          },
        },
        "gemini-3-flash-preview": {
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high",
              "includeThoughts": true,
            },
          },
        },
        "gemini-3-pro-preview": {
          "options": {
            "thinkingConfig": {
              "thinkingLevel": "high",
              "includeThoughts": true,
            },
          },
        },
      },
    },
  },
  "mode": {
    "brainstorm": {
      "model": "google/gemini-3.1-pro-preview",
      "temperature": 0.5,
      "prompt": "{file:./prompts/brainstorm.txt}",
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
      },
    },
    "plan": {
      "model": "google/gemini-3.1-pro-preview",
      "temperature": 0.1,
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
      },
    },
    "analyze": {
      "model": "google/gemini-3.1-pro-preview",
      "temperature": 0.1,
      "prompt": "{file:./prompts/analysis.txt}",
      "options": {
        "thinkingConfig": {
          "thinkingLevel": "high",
          "includeThoughts": true,
        },
      },
      "permission": {
        "bash": "deny",
        "edit": "deny",
        "write": "deny",
      },
    },
    "build": {
      "model": "google/gemini-3.5-flash",
      "temperature": 0.0,
    },
    "scout": {
      "model": "opencode/big-pickle",
      "temperature": 0.0,
    },
    "build-advanced": {
      "model": "opencode-go/glm-5.2",
      "temperature": 0.0,
      "prompt": "{file:./prompts/build-advanced.txt}",
    },
  },
}
