# OWASP NPM Security Cheat Sheet compliance
# https://cheatsheetseries.owasp.org/cheatsheets/NPM_Security_Cheat_Sheet.html

# Disable lifecycle scripts from dependencies (postinstall, prepare, etc.)
# Prevents supply chain attacks via malicious install scripts.
# Note: this also disables the project's own "prepare" script.
# Run "npx husky" manually after install to set up git hooks.
ignore-scripts=true

# Save exact versions when adding new dependencies (no ^ or ~ ranges).
# Combined with npm ci enforcement, this ensures deterministic installs
# and prevents pulling in compromised newly-published versions.
save-exact=true
